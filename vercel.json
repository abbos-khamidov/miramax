{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix \"mvp/first version\" ci",
  "buildCommand": "npm --prefix \"mvp/first version\" run build",
  "outputDirectory": "mvp/first version/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
